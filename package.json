{
  "name": "kysely-duckdb",
  "version": "0.3.0",
  "description": "kysely dialect for duckdb",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./wasm": {
      "types": "./dist/wasm.d.ts",
      "require": "./dist/wasm.js",
      "import": "./dist/wasm.mjs"
    },
    "./wasm-node": {
      "types": "./dist/wasm-node.d.ts",
      "require": "./dist/wasm-node.js",
      "import": "./dist/wasm-node.mjs"
    }
  },
  "scripts": {
    "test": "jest",
    "build": "rimraf ./dist && tsup src/index.ts src/wasm.ts src/wasm-node.ts --format cjs,esm --dts --sourcemap",
    "check": "tsc --noEmit",
    "docs": "typedoc src/index.ts",
    "all": "npm run check && npm run test && npm run build && npm run docs"
  },
  "keywords": [
    "kysely",
    "kysely-dialect",
    "duckdb"
  ],
  "author": "runoshun",
  "license": "MIT",
  "devDependencies": {
    "@duckdb/duckdb-wasm": "1.32.0",
    "@duckdb/node-api": "1.5.2-r.1",
    "@tsconfig/node18": "^18.2.2",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.7.0",
    "dprint": "^0.41.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "tsup": "^7.2.0",
    "typedoc": "^0.25.1",
    "typescript": "^5.2.2",
    "web-worker": "1.2.0"
  },
  "peerDependencies": {
    "@duckdb/duckdb-wasm": "*",
    "@duckdb/node-api": "*",
    "kysely": "*",
    "web-worker": "*"
  },
  "peerDependenciesMeta": {
    "@duckdb/duckdb-wasm": {
      "optional": true
    },
    "@duckdb/node-api": {
      "optional": true
    },
    "web-worker": {
      "optional": true
    }
  }
}
